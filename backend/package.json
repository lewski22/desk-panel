{
  "name": "desk-beacon-backend",
  "version": "0.17.0",
  "description": "Reserti Backend — NestJS 11 + Prisma 5 + PostgreSQL 15",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "ts-node src/database/seeds/seed.ts",
    "db:studio": "prisma studio",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0", "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0", "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0", "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^5.0.0", "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1", "class-validator": "^0.14.0",
    "jsonwebtoken": "^9.0.2", "jwks-rsa": "^3.1.0",
    "mqtt": "^5.0.0", "nodemailer": "^6.9.0",
    "passport": "^0.7.0", "passport-jwt": "^4.0.1", "passport-local": "^1.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2", "rxjs": "^7.8.0",
    "uuid": "^9.0.0", "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "botbuilder": "^4.23.3",
    "date-holidays": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0", "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.0", "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0", "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.0.0", "@types/nodemailer": "^6.4.0",
    "@types/passport-jwt": "^3.0.8", "@types/passport-local": "^1.0.35",
    "@types/uuid": "^9.0.2", "@types/web-push": "^3.6.4",
    "jest": "^29.7.0", "prisma": "^5.22.0",
    "ts-jest": "^29.1.0", "ts-node": "^10.9.1", "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": ["js","json","ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
