{
  "name": "desk-panel",
  "version": "0.1.0",
  "private": true,
  "description": "Reserti Desk Panel — backend + unified app",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:app\"",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:app": "cd apps/unified && npm run dev",
    "build:backend": "cd backend && npm run build",
    "build:app": "cd apps/unified && npm run build",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:migrate:prod": "cd backend && npx prisma migrate deploy",
    "db:seed": "cd backend && npm run db:seed",
    "db:generate": "cd backend && npx prisma generate",
    "db:studio": "cd backend && npx prisma studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f backend",
    "test:backend": "cd backend && npm run test"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
