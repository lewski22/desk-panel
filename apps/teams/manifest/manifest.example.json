{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.1.0",
  "id": "${TEAMS_APP_ID}",
  "packageName": "pl.reserti.deskbooking",
  "developer": {
    "name":         "Reserti",
    "websiteUrl":   "https://reserti.pl",
    "privacyUrl":   "https://reserti.pl/privacy",
    "termsOfUseUrl": "https://reserti.pl/terms"
  },
  "name": {
    "short": "Reserti",
    "full":  "Reserti — Desk Booking"
  },
  "description": {
    "short": "Zarezerwuj biurko w biurze",
    "full":  "Reserti pozwala rezerwować biurka hot-desk bezpośrednio z Microsoft Teams. Sprawdź dostępność, zarezerwuj i zarządzaj swoimi rezerwacjami bez wychodzenia z Teams."
  },
  "icons": {
    "color":   "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#9C2264",
  "staticTabs": [
    {
      "entityId":   "home",
      "name":       "Moje biurko",
      "contentUrl": "https://teams.prohalw2026.ovh/",
      "websiteUrl": "https://teams.prohalw2026.ovh/",
      "scopes":     ["personal"]
    },
    {
      "entityId":   "book",
      "name":       "Rezerwuj",
      "contentUrl": "https://teams.prohalw2026.ovh/book",
      "websiteUrl": "https://teams.prohalw2026.ovh/book",
      "scopes":     ["personal"]
    },
    {
      "entityId":   "mybookings",
      "name":       "Moje rezerwacje",
      "contentUrl": "https://teams.prohalw2026.ovh/my-bookings",
      "websiteUrl": "https://teams.prohalw2026.ovh/my-bookings",
      "scopes":     ["personal"]
    }
  ],
  "bots": [
    {
      "botId": "${TEAMS_BOT_APP_ID}",
      "scopes": ["personal", "team", "groupchat"],
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal"],
          "commands": [
            { "title": "book",         "description": "Zarezerwuj biurko na dziś" },
            { "title": "reservations", "description": "Moje nadchodzące rezerwacje" },
            { "title": "cancel",       "description": "Anuluj rezerwację: cancel <id>" },
            { "title": "help",         "description": "Lista dostępnych komend" }
          ]
        }
      ]
    }
  ],
  "composeExtensions": [
    {
      "botId": "${TEAMS_BOT_APP_ID}",
      "commands": [
        {
          "id":          "book",
          "type":        "action",
          "title":       "Zarezerwuj biurko",
          "description": "Otwórz formularz rezerwacji biurka",
          "context":     ["compose", "message"],
          "fetchTask":   true
        },
        {
          "id":          "reservations",
          "type":        "action",
          "title":       "Moje rezerwacje",
          "description": "Pokaż nadchodzące rezerwacje biurek",
          "context":     ["compose", "message"],
          "fetchTask":   true
        }
      ]
    }
  ],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "validDomains": [
    "teams.prohalw2026.ovh",
    "api.prohalw2026.ovh"
  ],
  "webApplicationInfo": {
    "id":       "${AZURE_CLIENT_ID}",
    "resource": "api://teams.prohalw2026.ovh/${AZURE_CLIENT_ID}"
  }
}
