# ── URLs (wymagane) ───────────────────────────────────────────
FRONTEND_URL="https://app.twojadomena.pl"
PUBLIC_API_URL="https://api.twojadomena.pl/api/v1"
ADMIN_URL="https://admin.twojadomena.pl"

# ── Database ──────────────────────────────────────────────────
# Lokalna / Docker: bez SSL (sieć wewnętrzna).
# Zewnętrzna baza (Neon, RDS, Supabase): dodaj ?sslmode=require na końcu URL.
DATABASE_URL="postgresql://user:password@localhost:5432/desk_panel"

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh"

# ── Web Push (VAPID) ──────────────────────────────────────────
# Generowanie kluczy: npx web-push generate-vapid-keys
# Lub: npm install -g web-push && web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@twojadomena.pl"

# ── MQTT / Gateway ────────────────────────────────────────────
GATEWAY_PROVISION_KEY="change-me"
# Gateway JWT — ODDZIELNY od JWT_SECRET użytkowników
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_GATEWAY_SECRET="change-me-gateway-jwt"

# ── Firmware OTA ──────────────────────────────────────────────
FIRMWARE_REPO="lewski22/desk-firmware"

# ── Email (SMTP) ──────────────────────────────────────────────
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="noreply@twojadomena.pl"

# ── WiFi credentials encryption (AES-256-GCM) ─────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WIFI_ENCRYPTION_KEY=your64hexcharskeyhere

# ── Integrations encryption (AES-256-GCM) ────────────────────
# Wymagany do szyfrowania tokenów i secretów integracji (Azure, Slack, itp.)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENCRYPTION_KEY=your64hexcharskeyhere

# ── Redis (opcjonalnie) ───────────────────────────────────────
# Wymagany tylko przy wielu instancjach backendu (nonce store dla Google OAuth).
# Bez ustawienia: fallback do in-memory (bezpieczne dla single-instance).
# REDIS_URL="redis://localhost:6379"

# ── Microsoft Azure SSO ───────────────────────────────────────
# AZURE_TENANT_ID=""
# AZURE_CLIENT_ID=""
# AZURE_CLIENT_SECRET=""
