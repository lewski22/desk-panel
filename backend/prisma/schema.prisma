// ============================================================
// Desk Beacon System — Prisma Schema
// PostgreSQL 15 · Prisma 7.x
// ============================================================

generator client {
  provider = "prisma-client-js"
  }

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  OWNER
  SUPER_ADMIN
  OFFICE_ADMIN
  STAFF
  END_USER
}

enum DeskStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
  COMPLETED
}

enum CheckinMethod {
  NFC
  QR
  MANUAL
}

enum EventType {
  DESK_CREATED
  DESK_UPDATED
  DESK_STATUS_CHANGED
  RESERVATION_CREATED
  RESERVATION_CANCELLED
  RESERVATION_EXPIRED
  CHECKIN_NFC
  CHECKIN_QR
  CHECKIN_MANUAL
  CHECKOUT
  DEVICE_ONLINE
  DEVICE_OFFLINE
  DEVICE_PROVISIONED
  GATEWAY_ONLINE
  GATEWAY_OFFLINE
  UNAUTHORIZED_SCAN
  USER_CREATED
  USER_UPDATED
  OWNER_IMPERSONATION
}

// ─── Organizations (multi-tenant root) ───────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Owner Panel — plan i metadane klienta
  plan           String    @default("starter")  // starter | pro | enterprise
  planExpiresAt  DateTime?
  trialEndsAt    DateTime?
  notes          String?   @db.Text
  contactEmail   String?
  createdBy      String?

  // M365 / Entra ID SSO (opcjonalne — per firma)
  azureTenantId  String?          // Tenant ID z Entra ID firmy-klienta
  azureEnabled   Boolean  @default(false)

  locations              Location[]
  users                  User[]
  events                 Event[]
  notificationSettings   NotificationSetting[]
  smtpConfig             OrganizationSmtpConfig?

}

// ─── Locations (offices) ─────────────────────────────────────

model Location {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  city           String?
  timezone       String   @default("Europe/Warsaw")
  isActive       Boolean  @default(true)
  // Godziny pracy biura (format HH:mm) — używane przy walk-in QR i walidacji rezerwacji
  openTime       String   @default("08:00")
  closeTime      String   @default("17:00")
  maxDaysAhead   Int      @default(14)   // Max N dni do przodu przy rezerwacji
  maxHoursPerDay Int      @default(8)    // Max długość jednej rezerwacji w godzinach
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  desks        Desk[]
  gateways     Gateway[]
  users        User[]            @relation("LocationUsers")
  setupTokens  GatewaySetupToken[]
}

// ─── Desks ───────────────────────────────────────────────────

model Desk {
  id         String     @id @default(cuid())
  locationId String
  name       String
  code       String
  floor      String?
  zone       String?
  status     DeskStatus @default(ACTIVE)
  qrToken    String     @unique @default(cuid())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  location     Location      @relation(fields: [locationId], references: [id])
  device       Device?
  reservations Reservation[]
  checkins     Checkin[]
  events       Event[]

  @@unique([locationId, code])
}

// ─── Devices (beacons) ───────────────────────────────────────

model Device {
  id              String   @id @default(cuid())
  deskId          String?  @unique
  gatewayId       String?
  hardwareId      String   @unique
  mqttUsername    String   @unique
  mqttPasswordHash String
  firmwareVersion String?
  lastSeen        DateTime?
  isOnline        Boolean  @default(false)
  rssi            Int?
  // OTA status tracking
  otaStatus       String?   // idle | in_progress | success | failed
  otaVersion      String?   // wersja docelowa (do której próbujemy zaktualizować)
  otaStartedAt    DateTime?
  otaFinishedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  desk     Desk?     @relation(fields: [deskId], references: [id])
  gateway  Gateway?  @relation(fields: [gatewayId], references: [id])
  events   Event[]
}

// ─── Gateways ────────────────────────────────────────────────

model Gateway {
  id           String    @id @default(cuid())
  locationId   String
  name         String
  secretHash              String
  secretHashPending       String?   // nowy secret w trakcie rotacji (okno 15min)
  secretPendingExpiresAt  DateTime? // kiedy wygasa okno migracji
  ipAddress    String?
  lastSeen     DateTime?
  isOnline     Boolean   @default(false)
  version      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  location    Location          @relation(fields: [locationId], references: [id])
  devices     Device[]
  events      Event[]
  setupTokens GatewaySetupToken[]
}

// Token jednorazowy do automatycznej instalacji gateway na Raspberry Pi
// Generowany przez Admin Panel → Biura → "Dodaj gateway"
// Ważny 24h, jednorazowy — po użyciu usedAt jest ustawiane
model GatewaySetupToken {
  id         String    @id @default(cuid())
  token      String    @unique @default(cuid())
  locationId String
  gatewayId  String?   // uzupełniane po pomyślnej instalacji
  createdBy  String    // userId admina który wygenerował
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  location Location  @relation(fields: [locationId], references: [id])
  gateway  Gateway?  @relation(fields: [gatewayId], references: [id])

  @@index([locationId])
}

// ─── Users ───────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  organizationId String?
  email          String    @unique
  passwordHash   String
  firstName      String?
  lastName       String?
  role           UserRole  @default(END_USER)
  cardUid        String?   @unique
  isActive       Boolean   @default(true)

  // M365 / Entra ID SSO
  azureObjectId  String?   @unique  // Azure AD object ID (oid z tokenu)
  azureTenantId  String?            // tenant użytkownika
  // Soft delete — konto dezaktywowane czeka na usunięcie po retentionDays
  deletedAt      DateTime?
  scheduledDeleteAt DateTime?   // data kiedy konto zostanie trwale usunięte
  retentionDays  Int?          // ile dni od dezaktywacji do trwałego usunięcia (min 30)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  locations    Location[]    @relation("LocationUsers")
  reservations Reservation[]
  checkins     Checkin[]
  refreshTokens RefreshToken[]
  events              Event[]             @relation("ActorEvents")
  inAppNotifications  InAppNotification[]
}

// ─── Refresh Tokens ──────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Reservations ────────────────────────────────────────────

model Reservation {
  id        String            @id @default(cuid())
  deskId    String
  userId    String
  date      DateTime          @db.Date
  startTime DateTime
  endTime   DateTime
  status    ReservationStatus @default(PENDING)
  qrToken   String            @unique @default(cuid())
  notes     String?
  checkedInAt  DateTime?      // kiedy nastąpił check-in (NFC lub QR)
  checkedInMethod String?     // NFC | QR | MANUAL
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  desk    Desk      @relation(fields: [deskId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id])
  checkin Checkin?
  events  Event[]
}

// ─── Checkins ────────────────────────────────────────────────

model Checkin {
  id            String        @id @default(cuid())
  reservationId String?       @unique
  deskId        String
  userId        String
  method        CheckinMethod
  cardUid       String?
  checkedInAt   DateTime      @default(now())
  checkedOutAt  DateTime?
  createdAt     DateTime      @default(now())

  reservation Reservation? @relation(fields: [reservationId], references: [id])
  desk        Desk         @relation(fields: [deskId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
}

// ─── Events (audit log) ──────────────────────────────────────

model Event {
  id             String    @id @default(cuid())
  organizationId String?
  type           EventType
  entityType     String?
  entityId       String?
  actorId        String?
  gatewayId      String?
  deviceId       String?
  deskId         String?
  reservationId  String?
  payload        Json?
  ts             DateTime  @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  actor        User?         @relation("ActorEvents", fields: [actorId], references: [id])
  gateway      Gateway?      @relation(fields: [gatewayId], references: [id])
  device       Device?       @relation(fields: [deviceId], references: [id])
  desk         Desk?         @relation(fields: [deskId], references: [id])
  reservation  Reservation?  @relation(fields: [reservationId], references: [id])

  @@index([type])
  @@index([entityId])
  @@index([actorId])
  @@index([ts])
}

// ─── Notifications ───────────────────────────────────────────

// Typy powiadomień obsługiwanych przez system
enum NotificationType {
  FIRMWARE_UPDATE_AVAILABLE   // Nowa wersja firmware dostępna na GitHub
  GATEWAY_OFFLINE             // Gateway stracił połączenie (lastSeen > 10min)
  BEACON_OFFLINE              // Beacon stracił połączenie (lastSeen > 10min)
  RESERVATION_CONFIRMED       // Potwierdzenie rezerwacji dla pracownika
  RESERVATION_REMINDER        // Przypomnienie 30min przed rezerwacją
  RESERVATION_CANCELLED       // Anulowanie rezerwacji
  CHECKIN_MISSED              // Brak check-in przy rezerwacji (auto-release)
  DAILY_REPORT                // Dzienny raport zajętości (07:00)
}

// Konfiguracja powiadomień per organizacja — zarządza SUPER_ADMIN
model NotificationSetting {
  id             String           @id @default(cuid())
  organizationId String
  type           NotificationType
  enabled        Boolean          @default(false)
  // Lista email adresów — JSON array: ["admin@firma.pl", "it@firma.pl"]
  // Jeśli puste — używany jest contactEmail organizacji lub SUPER_ADMINów
  recipients     String[]         @default([])
  // Opcjonalny próg dla alertów ilościowych (np. beacon offline > N min)
  thresholdMin   Int?             @default(10)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
}

// Log wysłanych powiadomień — audyt i deduplicacja
model NotificationLog {
  id             String           @id @default(cuid())
  organizationId String?
  type           NotificationType
  subject        String
  recipients     String[]
  // Klucz deduplikacji — np. "gateway:{id}:offline" — zapobiega spamowi
  dedupeKey      String?
  sentAt         DateTime         @default(now())
  success        Boolean          @default(true)
  errorMsg       String?

  @@index([organizationId, type, sentAt])
  @@index([dedupeKey, sentAt])
}

// Własna konfiguracja SMTP per organizacja (opcjonalna)
// Jeśli skonfigurowana — emaile tej org idą przez własny serwer
// Jeśli brak — fallback na globalny SMTP z env backendu
model OrganizationSmtpConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  host           String
  port           Int      @default(587)
  secure         Boolean  @default(false)
  user           String
  // Hasło szyfrowane AES-256-GCM (env: SMTP_ENCRYPTION_KEY)
  passwordEnc    String
  fromName       String   @default("Reserti")
  fromEmail      String
  isVerified     Boolean  @default(false)   // true po pomyślnym teście
  lastTestedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}


// ─── In-App Notification System ──────────────────────────────

// Typy zdarzeń wewnętrznych — niezależne od emaila
enum InAppNotifType {
  GATEWAY_OFFLINE         // Gateway stracił połączenie
  GATEWAY_BACK_ONLINE     // Gateway wrócił online
  BEACON_OFFLINE          // Beacon stracił połączenie
  FIRMWARE_UPDATE         // Nowa wersja firmware dostępna
  GATEWAY_RESET_NEEDED    // Gateway wymaga restartu / resetu
  RESERVATION_CHECKIN_MISSED // Brak check-in → biurko zwolnione
  SYSTEM_ANNOUNCEMENT     // Ogłoszenie od Ownera do firm
}

// Reguły powiadomień — Owner decyduje kto widzi co
// Każdy typ może być widoczny dla wybranych ról
model NotificationRule {
  id           String          @id @default(cuid())
  type         InAppNotifType  @unique
  // JSON array ról które widzą ten typ: ["SUPER_ADMIN","OFFICE_ADMIN"]
  targetRoles  String[]        @default([])
  enabled      Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

// Instancja powiadomienia dla konkretnego użytkownika
model InAppNotification {
  id             String         @id @default(cuid())
  userId         String
  organizationId String?
  type           InAppNotifType
  title          String
  body           String
  // Dodatkowe dane (np. gatewayId, deviceId) — JSON string
  meta           String?
  // Link do akcji (np. /provisioning)
  actionUrl      String?
  actionLabel    String?
  read           Boolean        @default(false)
  readAt         DateTime?
  createdAt      DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([organizationId, type, createdAt])
}

