// ============================================================
// Reserti — Prisma Schema v0.17.0
// GH baseline + sprints C/K/F + Tech Debt + Graph Sync
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────

enum UserRole {
  OWNER
  SUPER_ADMIN
  OFFICE_ADMIN
  STAFF
  END_USER
}

enum DeskStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
  COMPLETED
}

enum CheckinMethod {
  NFC
  QR
  MANUAL
  WEB
}

enum EventType {
  DESK_CREATED
  DESK_UPDATED
  DESK_STATUS_CHANGED
  RESERVATION_CREATED
  RESERVATION_CANCELLED
  RESERVATION_EXPIRED
  CHECKIN_NFC
  CHECKIN_QR
  CHECKIN_MANUAL
  CHECKOUT
  DEVICE_ONLINE
  DEVICE_OFFLINE
  DEVICE_PROVISIONED
  DEVICE_OTA_SUCCESS
  DEVICE_OTA_FAILED
  GATEWAY_ONLINE
  GATEWAY_OFFLINE
  GATEWAY_RESET
  UNAUTHORIZED_SCAN
  USER_CREATED
  USER_UPDATED
  OWNER_IMPERSONATION
}

enum NotificationType {
  FIRMWARE_UPDATE_AVAILABLE
  GATEWAY_OFFLINE
  BEACON_OFFLINE
  RESERVATION_CONFIRMED
  RESERVATION_REMINDER
  RESERVATION_CANCELLED
  CHECKIN_MISSED
  DAILY_REPORT
}

// Sprint F — Integration Marketplace (2026-04-18)
enum IntegrationProvider {
  AZURE_ENTRA
  SLACK
  GOOGLE_WORKSPACE
  MICROSOFT_TEAMS
  WEBHOOK_CUSTOM
}

// ─── Organization ─────────────────────────────────────────────

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  plan           String    @default("starter")
  planExpiresAt  DateTime?
  trialEndsAt    DateTime?
  notes          String?   @db.Text
  contactEmail   String?
  createdBy      String?

  limitDesks     Int?
  limitUsers     Int?
  limitGateways  Int?
  limitLocations Int?

  billingEmail   String?
  mrr            Int?
  nextInvoiceAt  DateTime?

  enabledModules  String[]  @default([])
  customAmenities String[]  @default([])

  passwordExpiryDays       Int?
  passwordMinLength        Int?      // null = system default (8)
  passwordRequireUppercase Boolean   @default(false)
  passwordRequireNumbers   Boolean   @default(false)
  passwordRequireSpecial   Boolean   @default(false)

  // Azure SSO — DEPRECATED in favour of OrgIntegration (kept for backward compat)
  azureTenantId  String?
  azureEnabled   Boolean   @default(false)

  locations            Location[]
  users                User[]
  subscriptionEvents   SubscriptionEvent[]
  events               Event[]
  notificationSettings NotificationSetting[]
  smtpConfig           OrganizationSmtpConfig?
  integrations         OrgIntegration[]         // Sprint F
  invitations          InvitationToken[]        // #15 Registration
}

// ─── Location ─────────────────────────────────────────────────

model Location {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  city           String?
  timezone       String   @default("Europe/Warsaw")
  isActive       Boolean  @default(true)
  openTime       String   @default("08:00")
  closeTime      String   @default("17:00")
  maxDaysAhead        Int    @default(14)
  maxHoursPerDay      Int    @default(8)
  parkingBookingMode  String @default("HOURLY")

  kioskPinHash   String?  // bcrypt hash; plaintext PIN never stored
  country        String?  // FEATURE P4-B3: ISO 3166-1 alpha-2 code for holiday-aware workday counting

  wifiSsidEnc    String?  // AES-256-GCM encrypted, format: hex(iv):hex(authTag):hex(ciphertext)
  wifiPassEnc    String?  // AES-256-GCM encrypted, format: hex(iv):hex(authTag):hex(ciphertext)

  ledBrightness         Int     @default(100)
  ledColorFree          String  @default("#00C800")
  ledColorReserved      String  @default("#0050DC")
  ledColorOccupied      String  @default("#DC0000")
  ledColorGuestReserved String  @default("#C8A000")

  floorPlanUrl   String?
  floorPlanKey   String?  // Tech Debt #3 — R2/S3 CDN key
  floorPlanW     Int?
  floorPlanH     Int?
  gridSize       Int?     @default(40)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  desks        Desk[]
  resources    Resource[]
  visitors     Visitor[]
  gateways     Gateway[]
  users        User[]            @relation("LocationUsers")
  setupTokens  GatewaySetupToken[]
  insights     UtilizationInsight[]  // Sprint K2
  floorPlans   LocationFloorPlan[]
}

// ─── LocationFloorPlan (per-floor plan images) ────────────────

model LocationFloorPlan {
  id           String   @id @default(cuid())
  locationId   String
  floor        String
  floorPlanUrl String?
  floorPlanKey String?
  floorPlanW   Int?
  floorPlanH   Int?
  gridSize     Int?     @default(40)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, floor])
  @@index([locationId])
}

// ─── Desk ────────────────────────────────────────────────────

model Desk {
  id         String     @id @default(cuid())
  locationId String
  name       String
  code       String
  floor      String?
  zone       String?
  status     DeskStatus @default(ACTIVE)
  qrToken    String     @unique @default(cuid())

  posX       Float?
  posY       Float?
  rotation   Int?       @default(0)
  width      Float?     @default(2)
  height     Float?     @default(1)

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  location     Location      @relation(fields: [locationId], references: [id])
  device       Device?
  reservations Reservation[]
  checkins     Checkin[]
  events       Event[]

  @@unique([locationId, code])
}

// ─── Device (beacon) ─────────────────────────────────────────

model Device {
  id               String    @id @default(cuid())
  deskId           String?   @unique
  gatewayId        String?
  hardwareId       String    @unique
  mqttUsername     String    @unique
  mqttPasswordHash String
  firmwareVersion  String?
  lastSeen         DateTime?
  isOnline         Boolean   @default(false)
  rssi             Int?

  otaStatus       String?
  otaVersion      String?
  otaStartedAt    DateTime?
  otaFinishedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  desk    Desk?    @relation(fields: [deskId], references: [id])
  gateway Gateway? @relation(fields: [gatewayId], references: [id])
  events  Event[]
}

// ─── Gateway ─────────────────────────────────────────────────

model Gateway {
  id                     String    @id @default(cuid())
  locationId             String
  name                   String
  secretHash             String
  secretRaw              String?   // plain-text secret for HMAC auth; set on register/rotate
  secretHashPending      String?
  secretPendingExpiresAt DateTime?
  ipAddress              String?
  lastSeen               DateTime?
  isOnline               Boolean   @default(false)
  version                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  location    Location            @relation(fields: [locationId], references: [id])
  devices     Device[]
  events      Event[]
  setupTokens GatewaySetupToken[]
}

model GatewaySetupToken {
  id         String    @id @default(cuid())
  token      String    @unique @default(cuid())
  locationId String
  gatewayId  String?
  createdBy  String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  location Location @relation(fields: [locationId], references: [id])
  gateway  Gateway? @relation(fields: [gatewayId], references: [id])

  @@index([locationId])
}

// ─── User ────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  organizationId String?
  email          String    @unique
  passwordHash   String
  firstName      String?
  lastName       String?
  role           UserRole  @default(END_USER)
  cardUid        String?   @unique
  isActive       Boolean   @default(true)

  azureObjectId     String?   @unique
  azureTenantId     String?
  deletedAt         DateTime?
  scheduledDeleteAt DateTime?
  retentionDays     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mustChangePassword  Boolean   @default(false)
  passwordChangedAt   DateTime?

  organization       Organization?   @relation(fields: [organizationId], references: [id])
  locations          Location[]      @relation("LocationUsers")
  reservations       Reservation[]
  checkins           Checkin[]
  refreshTokens      RefreshToken[]
  events             Event[]         @relation("ActorEvents")
  inAppNotifications InAppNotification[]
  bookings           Booking[]
  pushSubscriptions  PushSubscription[]
  hostedVisitors     Visitor[]       @relation("HostedVisitors")
  graphToken         GraphToken?          // M4
  graphSubscriptions GraphSubscription[]  // M4
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Reservation ─────────────────────────────────────────────

model Reservation {
  id                String            @id @default(cuid())
  deskId            String
  userId            String
  date              DateTime          @db.Date
  startTime         DateTime
  endTime           DateTime
  status            ReservationStatus @default(PENDING)
  qrToken           String            @unique @default(cuid())
  notes             String?
  checkedInAt       DateTime?
  checkedInMethod   String?

  recurrenceRule    String?
  recurrenceGroupId String?

  graphEventId      String?   // M4 — Outlook Calendar event ID
  reservationType   String    @default("STANDARD")  // FEATURE P4-B1: STANDARD | GUEST | TEAM

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  desk    Desk        @relation(fields: [deskId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])
  checkin Checkin?
  events  Event[]

  @@index([deskId, date, status])
}

// ─── Checkin ─────────────────────────────────────────────────

model Checkin {
  id            String        @id @default(cuid())
  reservationId String?       @unique
  deskId        String
  userId        String
  method        CheckinMethod
  cardUid       String?
  checkedInAt   DateTime      @default(now())
  checkedOutAt  DateTime?
  createdAt     DateTime      @default(now())

  reservation Reservation? @relation(fields: [reservationId], references: [id])
  desk        Desk         @relation(fields: [deskId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])

  @@index([deskId, checkedOutAt])
}

// ─── Resource (Room / Parking / Equipment) ────────────────────

model Resource {
  id          String   @id @default(cuid())
  locationId  String
  type        String
  name        String
  code        String
  description String?
  capacity    Int?
  amenities   String[] @default([])
  vehicleType String?
  floor       String?
  zone        String?
  status      String   @default("ACTIVE")
  posX        Float?
  posY        Float?
  rotation    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  location Location  @relation(fields: [locationId], references: [id])
  bookings Booking[]
}

model Booking {
  id         String   @id @default(cuid())
  resourceId String
  userId     String
  date       DateTime @db.Date
  startTime  DateTime
  endTime    DateTime
  status     String   @default("CONFIRMED")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resource Resource @relation(fields: [resourceId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}

// ─── Visitor ─────────────────────────────────────────────────

model Visitor {
  id           String    @id @default(cuid())
  locationId   String
  hostUserId   String
  firstName    String
  lastName     String?
  email        String?
  company      String?
  visitDate    DateTime
  purpose      String?
  status       String    @default("INVITED")
  qrToken      String    @unique @default(cuid())
  checkedInAt  DateTime?
  checkedOutAt DateTime?
  createdAt    DateTime  @default(now())

  location Location @relation(fields: [locationId], references: [id])
  host     User     @relation("HostedVisitors", fields: [hostUserId], references: [id])
}

// ─── Push Subscription ───────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Subscription & Billing ──────────────────────────────────

model SubscriptionEvent {
  id             String   @id @default(cuid())
  organizationId String
  type           String
  previousPlan   String?
  newPlan        String?
  changedBy      String?
  note           String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
}

model PlanTemplate {
  plan      String   @id
  desks     Int?
  users     Int?
  gateways  Int?
  locations Int?
  ota       Boolean  @default(false)
  sso       Boolean  @default(false)
  smtp      Boolean  @default(false)
  api       Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// ─── Notifications ───────────────────────────────────────────

model NotificationSetting {
  id             String           @id @default(cuid())
  organizationId String
  type           NotificationType
  enabled        Boolean          @default(false)
  recipients     String[]         @default([])
  thresholdMin   Int?             @default(10)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
}

model NotificationLog {
  id             String           @id @default(cuid())
  organizationId String?
  type           NotificationType
  subject        String
  recipients     String[]
  dedupeKey      String?
  sentAt         DateTime         @default(now())
  success        Boolean          @default(true)
  errorMsg       String?
}

model InAppNotification {
  id          String    @id @default(cuid())
  userId      String
  type        String
  title       String
  body        String
  read        Boolean   @default(false)
  readAt      DateTime?
  actionUrl   String?
  actionLabel String?
  meta        String?
  dedupeKey   String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([dedupeKey])
}

model NotificationRule {
  id          String   @id @default(cuid())
  type        String   @unique
  enabled     Boolean  @default(true)
  targetRoles String[] @default([])
  updatedAt   DateTime @updatedAt
}

// ─── SMTP per org ─────────────────────────────────────────────

model OrganizationSmtpConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  host           String
  port           Int      @default(587)
  secure         Boolean  @default(false)
  user           String
  passwordEnc    String
  fromName       String   @default("Reserti")
  fromEmail      String
  isVerified     Boolean  @default(false)
  lastTestedAt   DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── Event audit log ─────────────────────────────────────────

model Event {
  id             String    @id @default(cuid())
  organizationId String?
  type           EventType
  entityType     String?
  entityId       String?
  actorId        String?
  gatewayId      String?
  deviceId       String?
  deskId         String?
  reservationId  String?
  payload        Json?
  ts             DateTime  @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  actor        User?         @relation("ActorEvents", fields: [actorId], references: [id])
  gateway      Gateway?      @relation(fields: [gatewayId], references: [id])
  device       Device?       @relation(fields: [deviceId], references: [id])
  desk         Desk?         @relation(fields: [deskId], references: [id])
  reservation  Reservation?  @relation(fields: [reservationId], references: [id])

  @@index([type])
  @@index([entityId])
  @@index([ts])
}

// ─── Sprint F — OrgIntegration ───────────────────────────────

model OrgIntegration {
  id               String              @id @default(cuid())
  organizationId   String
  provider         IntegrationProvider
  isEnabled        Boolean             @default(false)
  configEncrypted  String?
  displayName      String?
  tenantHint       String?
  lastTestedAt     DateTime?
  lastTestOk       Boolean?
  lastTestError    String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@index([organizationId])
}

// ─── Sprint K2 — UtilizationInsight ──────────────────────────

model UtilizationInsight {
  id          String   @id @default(cuid())
  locationId  String
  orgId       String
  generatedAt DateTime @default(now())
  periodDays  Int      @default(30)
  insights    Json     @default("[]")

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId])
  @@index([orgId, generatedAt(sort: Desc)])
}

// ─── M4 — Microsoft Graph Sync ───────────────────────────────

model GraphToken {
  id              String   @id @default(cuid())
  userId          String   @unique
  organizationId  String
  accessTokenEnc  String
  refreshTokenEnc String
  expiresAt       DateTime
  scope           String   @default("Calendars.ReadWrite offline_access User.Read")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([expiresAt])
}

// ─── InvitationToken (#15 Registration flow) ─────────────────

model InvitationToken {
  id             String    @id @default(cuid())
  token          String    @unique @default(cuid())
  email          String
  organizationId String
  role           UserRole  @default(END_USER)
  invitedById    String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([organizationId])
}

model GraphSubscription {
  id             String   @id @default(cuid())
  userId         String
  subscriptionId String   @unique
  calendarId     String   @default("primary")
  expiresAt      DateTime
  clientState    String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
